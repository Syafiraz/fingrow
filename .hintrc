{
  "extends": [
    "development"
  ],
  "hints": {
    "no-inline-styles": "off",
    "axe/forms": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "-moz-appearance",
          "backdrop-filter"
        ]
      }
    ],
    "button-type": "off",
    "axe/name-role-value": [
      "default",
      {
        "button-name": "off"
      }
    ],
    "css-prefix-order": "off"
  }
}